# --- Data ---
# Raw and processed data are not tracked by default; keep the folders via
# .gitkeep but ignore their contents. Adjust when a data-versioning strategy
# (e.g. DVC, git-lfs) is chosen.
# Exceptions: doi_list.csv and manifest.json are hand-curated pipeline inputs
# and are tracked.
data/raw/*
data/processed/*
!data/**/.gitkeep
!data/raw/doi_list.csv
!data/raw/manifest.json

# Generated artifacts
outputs/*
!outputs/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# --- Jupyter ---
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# --- Environment & secrets ---
.env
.env.*
*.local
secrets.*
credentials.*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Logs ---
*.log
logs/
