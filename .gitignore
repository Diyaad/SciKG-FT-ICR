# --- Data ---
# Raw and processed data are not tracked by default; keep the folders via
# .gitkeep but ignore their contents.
# Exceptions: hand-curated inputs in data/raw/, CrossRef fetched JSONs,
# FOXDEN RAW file metadata, and processed entity/relationship outputs.
# These are tracked so reviewers can see the graph data without re-running
# the pipeline.
data/raw/*
data/processed/*
!data/**/.gitkeep
!data/raw/doi_list.csv
!data/raw/manifest.json
!data/raw/maglab_icr_publications.csv
!data/raw/rawfile_metadata.csv
!data/raw/publications/
!data/raw/publications/*.json
!data/raw/rawfiles_metadata/
!data/raw/rawfiles_metadata/*.json
!data/processed/entities/
!data/processed/entities/*.jsonl
!data/processed/relationships/
!data/processed/relationships/*.jsonl
!data/processed/rawfiles_enriched/
!data/processed/rawfiles_enriched/*.json

# Generated artifacts
outputs/*
!outputs/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# --- Jupyter ---
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# --- Environment & secrets ---
.env
.env.*
*.local
secrets.*
credentials.*

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Logs ---
*.log
logs/
